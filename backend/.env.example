# Les secrets vivent dans Google Secret Manager — voir docs/SECRET_MANAGER.md
#
# Migration (une fois, si vous avez déjà un .env local) :
#   ./scripts/sync-env-to-secret-manager.sh --push --target backend
#
# Dev local sans GSM :
#   export FORMA_USE_LOCAL_ENV=1
#   cp .env.example .env   # puis remplir les clés
# Si backend/.env existe, GSM est ignoré automatiquement (démarrage plus rapide).
#
# Dev local avec GSM (défaut) :
#   gcloud auth application-default login
#   cd backend && uvicorn app.main:app --reload --port 8000

# --- Grok (xAI) — recommandé pour @Modelling + image ---
FORMA_LLM_PROVIDER=xai
XAI_API_KEY=
XAI_MODEL=grok-4.3
XAI_VISION_MODEL=grok-4.3
# @Modelling — grok-4.3 (image) + grok-4.20-0309-reasoning (JSON CAO)
XAI_MODELLING_VISION_MODEL=grok-4.3
XAI_MODELLING_CAD_MODEL=grok-4.20-0309-reasoning

# Pipeline @Modelling : 2 appels (analyse image puis CAO) — recommandé
FORMA_MODELLING_TWO_PHASE=1

# Logs erreurs LLM dans la console backend (debug local)
# FORMA_LLM_DEBUG=1

# --- Alternatives ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# FORMA_AUTO_CHAT_MODEL=gpt-4.1-nano
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# auto | xai | openai | anthropic
# FORMA_LLM_PROVIDER=auto

# --- Firebase (auth utilisateur + clés API cloud) ---
FIREBASE_PROJECT_ID=forma-cad-dev
# GOOGLE_APPLICATION_CREDENTIALS=/chemin/vers/service-account.json
# Vercel : collez le JSON complet dans FIREBASE_SERVICE_ACCOUNT_JSON (une ligne)
# App bureau : copiez aussi le JSON dans forma-data/firebase-adminsdk.json

# FORMA_OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
# FORMA_FRONTEND_ORIGIN=http://127.0.0.1:5173
# Chemin Vite de l'app (redirect OAuth après connexion) :
# FORMA_FRONTEND_BASE_PATH=/app

# --- Connecteurs OAuth (Calendar, Gmail, Outlook, Spotify) ---
# Redirect URI obligatoire pour tous :
#   http://127.0.0.1:8000/api/connectors/oauth/callback
# FORMA_OAUTH_REDIRECT_BASE=http://127.0.0.1:8000
# FORMA_FRONTEND_ORIGIN=http://127.0.0.1:5173
# Chemin Vite de l'app (redirect OAuth après connexion) :
# FORMA_FRONTEND_BASE_PATH=/app

# Google Calendar + Gmail (Google Cloud Console → OAuth client Web)
# Activer "Google Calendar API" et "Gmail API" dans APIs & Services → Library
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Outlook (Azure Portal → App registrations → Authentication → Web redirect URI)
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT=common

# Spotify (developer.spotify.com/dashboard → Create app → Settings → Redirect URIs)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# --- Quota IA Pro (prix retail = coût fournisseur × marge, input/output séparés) ---
# FORMA_USAGE_MARKUP=1.25
# FORMA_ON_DEMAND_USAGE_MARKUP=1.65
# FORMA_PRO_USAGE_ALLOWANCE_USD=30
# FORMA_ENTERPRISE_USAGE_ALLOWANCE_USD_PER_SEAT=25
# Tarifs fournisseur USD / 1M tokens (input, output) — voir OpenAI, xAI, Anthropic
# FORMA_MODEL_PROVIDER_RATES={"gpt-4.1-nano":{"input":0.10,"output":0.40},"gpt-4o-mini":{"input":0.15,"output":0.60},"grok-3-mini":{"input":1.25,"output":2.50},"grok-4.1":{"input":1.25,"output":2.50},"grok-4.3":{"input":1.25,"output":2.50},"grok-cad-reasoning":{"input":1.25,"output":2.50},"claude-opus-4-7":{"input":5.00,"output":25.00},"claude-opus-4-8":{"input":5.00,"output":25.00}}
