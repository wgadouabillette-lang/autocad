# Config frontend — secret GSM `forma-frontend-env`
# Voir docs/SECRET_MANAGER.md
#
# En dev, `npm run dev` télécharge ce bundle depuis Secret Manager.
# Repli local : FORMA_USE_LOCAL_ENV=1

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=forma-cad-dev.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=forma-cad-dev
VITE_FIREBASE_STORAGE_BUCKET=forma-cad-dev.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_REGION=europe-west1

# URL de la page web d'authentification bureau (Google / Microsoft / Facebook).
# Dev : laisser vide (utilise http://127.0.0.1:<port>/auth/desktop automatiquement).
# Prod desktop : https://forma-cad-dev.web.app/auth
VITE_FORMA_WEB_AUTH_URL=

# Optionnel — tenant Azure AD pour Microsoft (défaut: common = comptes perso + pro).
# VITE_MICROSOFT_OAUTH_TENANT=common

# Optionnel — serveur TURN dédié (sinon relais public de secours en dev).
# VITE_TURN_URL=turn:your-turn.example.com:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
