# Secrets dans Google Secret Manager — secret `forma-functions-env`
# Voir docs/SECRET_MANAGER.md
#
# Migration :
#   ./scripts/sync-env-to-secret-manager.sh --push --target functions
#
# Alternative : secrets Firebase individuels
#   firebase functions:secrets:set STRIPE_SECRET_KEY

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ON_DEMAND_PRICE_ID=price_...
STRIPE_ON_DEMAND_UNIT_CENTS=1
STRIPE_ENTERPRISE_SEAT_PRICE_ID=price_...

# FORMA_USAGE_MARKUP=1.25
# FORMA_ON_DEMAND_USAGE_MARKUP=1.65

# Clés LLM plateforme (optionnel — les utilisateurs peuvent aussi configurer les leurs)
# XAI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
