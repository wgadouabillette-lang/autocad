# Credentials OAuth pour Firebase Authentication (Microsoft + Facebook).
# Copiez ce fichier en oauth.env (gitignored), remplissez les valeurs, puis :
#   ./scripts/setup-facebook-login.sh
# ou
#   ./scripts/configure-firebase-oauth-providers.sh
#
# Projet Firebase par défaut : forma-cad-dev

FACEBOOK_OAUTH_APP_ID=
FACEBOOK_OAUTH_APP_SECRET=

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
