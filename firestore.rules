rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidProfile() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'userDisplayName', 'updatedAt'])
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 320
        && data.userDisplayName is string
        && data.userDisplayName.size() >= 1
        && data.userDisplayName.size() <= 120
        && data.updatedAt is timestamp;
    }

    function isValidDirectoryProfile(uid) {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'email', 'displayName', 'updatedAt'])
        && data.uid == uid
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 320
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 120
        && (!('photoURL' in data) || data.photoURL == null || data.photoURL is string)
        && data.updatedAt is timestamp;
    }

    function isValidFriendRequest() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'fromUid', 'fromName', 'fromEmail', 'toEmail', 'status', 'createdAt'])
        && data.id is string
        && data.fromUid == request.auth.uid
        && data.fromName is string
        && data.fromName.size() >= 1
        && data.fromName.size() <= 120
        && data.fromEmail is string
        && data.fromEmail.size() > 3
        && data.fromEmail.size() <= 320
        && data.toEmail is string
        && data.toEmail.size() > 3
        && data.toEmail.size() <= 320
        && data.status == 'pending'
        && data.createdAt is timestamp;
    }

    function isFriendRequestResponse() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt', 'toUid'])
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.respondedAt is timestamp
        && request.resource.data.toUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfile();
      allow update: if isOwner(uid) && isValidProfile()
        && request.resource.data.email == resource.data.email;

      match /workspaces/{workspaceId} {
        allow read, write: if isOwner(uid);
      }

      match /memberships/{membershipId} {
        allow read, write: if isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(uid);
      }

      match /chatSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }

      match /friends/{friendUid} {
        allow read, write: if isOwner(uid);
      }

      match /private/{document=**} {
        allow read, write: if false;
      }
    }

  match /userDirectory/{uid} {
    allow read: if isSignedIn();
    allow create, update: if isOwner(uid) && isValidDirectoryProfile(uid);
    allow delete: if false;
  }

  match /friendRequests/{requestId} {
    allow read: if isSignedIn() && (
      request.auth.token.email == resource.data.toEmail
      || request.auth.uid == resource.data.fromUid
    );
    allow create: if isSignedIn() && isValidFriendRequest();
    allow update: if isSignedIn()
      && request.auth.token.email == resource.data.toEmail
      && resource.data.status == 'pending'
      && isFriendRequestResponse();
    allow delete: if false;
  }

  match /friendChats/{chatId} {
    allow read: if isSignedIn()
      && resource.data.participants is list
      && request.auth.uid in resource.data.participants;
    allow create: if isSignedIn()
      && request.resource.data.participants is list
      && request.resource.data.participants.size() == 2
      && request.auth.uid in request.resource.data.participants;
    allow update: if isSignedIn()
      && request.auth.uid in resource.data.participants
      && request.resource.data.participants == resource.data.participants;
    allow delete: if false;

    match /messages/{messageId} {
      allow read: if isSignedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 4000
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }
  }

  match /desktopAuthSessions/{sessionId} {
    allow create: if request.auth != null
      && request.resource.data.keys().hasAll(["provider", "idToken", "createdAt"])
      && request.resource.data.provider in ["google", "microsoft", "apple"]
      && request.resource.data.idToken is string
      && request.resource.data.idToken.size() > 100;
    allow read, delete: if true;
    allow update: if false;
  }

  match /workspacesShared/{workspaceId}/presence/{uid} {
    allow read: if isSignedIn();
    allow create, update: if isOwner(uid)
      && request.resource.data.uid == uid
      && request.resource.data.displayName is string
      && request.resource.data.displayName.size() >= 1
      && request.resource.data.displayName.size() <= 120
      && request.resource.data.lastSeen is timestamp
      && (!('photoURL' in request.resource.data)
        || request.resource.data.photoURL == null
        || request.resource.data.photoURL is string);
    allow delete: if isOwner(uid);
  }
}
}