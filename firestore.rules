rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function sharedWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspacesShared/$(workspaceId));
    }

    function isSharedWorkspaceOwner(workspaceId) {
      return isSignedIn() && sharedWorkspace(workspaceId).data.ownerId == request.auth.uid;
    }

    function isValidProfile() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'userDisplayName', 'updatedAt'])
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 320
        && data.userDisplayName is string
        && data.userDisplayName.size() >= 1
        && data.userDisplayName.size() <= 120
        && data.updatedAt is timestamp;
    }

    function isValidDirectoryProfile(uid) {
      let data = request.resource.data;
      return data.keys().hasAll(['uid', 'email', 'displayName', 'updatedAt'])
        && data.uid == uid
        && data.email is string
        && data.email.size() > 3
        && data.email.size() <= 320
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 120
        && (!('photoURL' in data) || data.photoURL == null || data.photoURL is string)
        && data.updatedAt is timestamp;
    }

    function isValidFriendRequest() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'fromUid', 'fromName', 'fromEmail', 'toEmail', 'status', 'createdAt'])
        && data.id is string
        && data.fromUid == request.auth.uid
        && data.fromName is string
        && data.fromName.size() >= 1
        && data.fromName.size() <= 120
        && data.fromEmail is string
        && data.fromEmail.size() > 3
        && data.fromEmail.size() <= 320
        && data.toEmail is string
        && data.toEmail.size() > 3
        && data.toEmail.size() <= 320
        && data.status == 'pending'
        && data.createdAt is timestamp;
    }

    function isFriendRequestResponse() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt', 'toUid'])
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.respondedAt is timestamp
        && request.resource.data.toUid == request.auth.uid;
    }

    function isFriendChatMember(chatId) {
      let chat = get(/databases/$(database)/documents/friendChats/$(chatId));
      return chat.data.participants is list
        && request.auth.uid in chat.data.participants;
    }

    function canReadFriendChatMessage(chatId) {
      return isSignedIn()
        && (
          ('participants' in resource.data
            && resource.data.participants is list
            && request.auth.uid in resource.data.participants)
          || isFriendChatMember(chatId)
        );
    }

    function isFriendChatMessagesPath(path) {
      return path.matches('friendChats/[^/]+');
    }

    function friendChatIdFromMessagesPath(path) {
      return path.split('/')[1];
    }

    function isValidSharedWorkspaceCreate(workspaceId) {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'name', 'accent', 'ownerId', 'ownerName', 'createdAt'])
        && data.id == workspaceId
        && data.ownerId == request.auth.uid
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 120
        && data.accent is string
        && data.ownerName is string
        && data.ownerName.size() >= 1
        && data.ownerName.size() <= 120
        && data.createdAt is number;
    }

    function isValidSharedWorkspaceUpdate() {
      let data = request.resource.data;
      return data.id == resource.data.id
        && data.ownerId == resource.data.ownerId
        && data.createdAt == resource.data.createdAt
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 120
        && data.accent is string
        && data.ownerName is string
        && data.ownerName.size() >= 1
        && data.ownerName.size() <= 120;
    }

    function isValidJoinRequestCreate(requesterUid) {
      let data = request.resource.data;
      return requesterUid == request.auth.uid
        && data.keys().hasAll(['requesterUid', 'requesterName', 'requesterEmail', 'status', 'createdAt'])
        && data.requesterUid == request.auth.uid
        && data.requesterName is string
        && data.requesterName.size() >= 1
        && data.requesterName.size() <= 120
        && data.requesterEmail is string
        && data.requesterEmail.size() > 3
        && data.requesterEmail.size() <= 320
        && data.status == 'pending'
        && data.createdAt is timestamp;
    }

    function isJoinRequestResponse() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt'])
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.respondedAt is timestamp
        && resource.data.status == 'pending';
    }

    function isValidPresenceWrite(uid) {
      let data = request.resource.data;
      return data.uid == uid
        && data.displayName is string
        && data.displayName.size() >= 1
        && data.displayName.size() <= 120
        && data.lastSeen is timestamp
        && (!('photoURL' in data)
          || data.photoURL == null
          || data.photoURL is string)
        && (!('voiceInPrivateCall' in data) || data.voiceInPrivateCall is bool)
        && (!('voiceOpenChannelId' in data)
          || data.voiceOpenChannelId == null
          || data.voiceOpenChannelId is string)
        && (!('voiceSpeaking' in data) || data.voiceSpeaking is bool)
        && (!('presenceActivity' in data)
          || data.presenceActivity == null
          || (data.presenceActivity is string && data.presenceActivity.size() <= 32));
    }

    function isValidOpenVoiceChannelWrite(workspaceId, channelId) {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'workspaceId', 'name'])
        && data.id == channelId
        && data.workspaceId == workspaceId
        && data.name is string
        && data.name.size() >= 1
        && data.name.size() <= 120;
    }

    function isValidVoicePollWrite() {
      let data = request.resource.data;
      return data.keys().hasAll(['id', 'workspaceId', 'question', 'options', 'status', 'createdAt', 'expiresAt', 'createdByUserId', 'createdByName'])
        && data.id is string
        && data.workspaceId is string
        && data.question is string
        && data.question.size() >= 1
        && data.question.size() <= 500
        && data.options is list
        && data.status in ['open', 'closed']
        && data.createdAt is number
        && data.expiresAt is number
        && data.createdByUserId is string
        && data.createdByName is string
        && data.createdByName.size() >= 1
        && data.createdByName.size() <= 120;
    }

    function isValidVoicePollPatch() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return changed.hasOnly(['votesByUserId', 'updatedAt'])
        || changed.hasOnly(['status', 'updatedAt']);
    }

    function isVoiceKnockReopen(fromUid) {
      return fromUid == request.auth.uid
        && resource.data.fromUid == request.auth.uid
        && resource.data.status in ['declined', 'accepted']
        && request.resource.data.status == 'pending'
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid == resource.data.toUid;
    }

    function isValidVoiceEjectCreate() {
      let data = request.resource.data;
      return data.fromUid == request.auth.uid
        && data.keys().hasAll(['id', 'workspaceId', 'fromUid', 'fromName', 'toUid', 'status', 'createdAt'])
        && data.fromName is string
        && data.fromName.size() >= 1
        && data.fromName.size() <= 120
        && data.toUid is string
        && data.toUid.size() >= 1
        && data.toUid != request.auth.uid
        && data.status == 'ejected'
        && data.createdAt is timestamp;
    }

    function isValidVoiceKnockCreate(fromUid) {
      let data = request.resource.data;
      return fromUid == request.auth.uid
        && data.keys().hasAll(['id', 'workspaceId', 'fromUid', 'fromName', 'toUid', 'status', 'createdAt'])
        && data.fromUid == request.auth.uid
        && data.fromName is string
        && data.fromName.size() >= 1
        && data.fromName.size() <= 120
        && data.toUid is string
        && data.toUid.size() >= 1
        && data.toUid != request.auth.uid
        && data.status == 'pending'
        && data.createdAt is timestamp;
    }

    function isVoiceKnockResponse(toUid) {
      return toUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt'])
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.respondedAt is timestamp
        && resource.data.status == 'pending';
    }

    function isVoiceKnockCancel(fromUid) {
      return fromUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'respondedAt'])
        && request.resource.data.status == 'declined'
        && request.resource.data.respondedAt is timestamp
        && resource.data.status == 'pending';
    }

    function isRtcSignalParticipant() {
      return isSignedIn() && (
        request.auth.uid == resource.data.fromUid
        || request.auth.uid == resource.data.toUid
      );
    }

    function isValidRtcSignalCreate() {
      let data = request.resource.data;
      return isSignedIn()
        && data.fromUid == request.auth.uid
        && data.toUid is string
        && data.toUid.size() >= 1
        && data.toUid != request.auth.uid
        && data.type in ['offer', 'answer', 'candidate']
        && data.createdAt is timestamp
        && (!('sdp' in data) || data.sdp == null || data.sdp is string)
        && (!('candidate' in data) || data.candidate == null || data.candidate is map);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfile();
      allow update: if isOwner(uid) && isValidProfile()
        && request.resource.data.email == resource.data.email;

      match /workspaces/{workspaceId} {
        allow read, write: if isOwner(uid);
      }

      match /memberships/{membershipId} {
        allow read, write: if isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(uid);
      }

      match /chatSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }

      match /friends/{friendUid} {
        allow read, write: if isOwner(uid);
      }

      match /private/{document=**} {
        allow read, write: if false;
      }
    }

    match /userDirectory/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid) && isValidDirectoryProfile(uid);
      allow delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == resource.data.toEmail
        || request.auth.uid == resource.data.fromUid
      );
      allow create: if isSignedIn() && isValidFriendRequest();
      allow update: if isSignedIn()
        && request.auth.token.email == resource.data.toEmail
        && resource.data.status == 'pending'
        && isFriendRequestResponse();
      allow delete: if false;
    }

    match /{path=**}/messages/{messageId} {
      // Collection-group inbox query filters on participants; avoid get() here.
      allow read: if isSignedIn()
        && isFriendChatMessagesPath(path)
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
      allow create, update, delete: if false;
    }

    match /friendChats/{chatId} {
      allow read: if isSignedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if canReadFriendChatMessage(chatId);
        allow create: if isSignedIn()
          && isFriendChatMember(chatId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.participants is list
          && request.resource.data.participants.size() == 2
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000
          && request.resource.data.createdAt is timestamp;
        allow update, delete: if false;
      }
    }

    match /desktopAuthSessions/{sessionId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(["provider", "idToken", "createdAt"])
        && request.resource.data.provider in ["google", "microsoft", "apple"]
        && request.resource.data.idToken is string
        && request.resource.data.idToken.size() > 100;
      allow read, delete: if true;
      allow update: if false;
    }

    match /workspacesShared/{workspaceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSharedWorkspaceCreate(workspaceId);
      allow update: if isSharedWorkspaceOwner(workspaceId) && isValidSharedWorkspaceUpdate();
      allow delete: if false;

      match /joinRequests/{requesterUid} {
        allow read: if isSignedIn() && (
          request.auth.uid == requesterUid
          || isSharedWorkspaceOwner(workspaceId)
        );
        allow create: if isSignedIn() && isValidJoinRequestCreate(requesterUid);
        allow update: if isSharedWorkspaceOwner(workspaceId) && isJoinRequestResponse();
        allow delete: if false;
      }

      match /members/{memberUid} {
        allow read: if isSignedIn() && (
          request.auth.uid == memberUid
          || isSharedWorkspaceOwner(workspaceId)
        );
        allow create, update: if isSharedWorkspaceOwner(workspaceId)
          && request.resource.data.uid == memberUid
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() >= 1
          && request.resource.data.displayName.size() <= 120
          && request.resource.data.email is string
          && request.resource.data.email.size() <= 320
          && request.resource.data.joinedAt is timestamp;
        allow delete: if isSharedWorkspaceOwner(workspaceId);
      }

      match /presence/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid) && isValidPresenceWrite(uid);
        allow delete: if isOwner(uid);
      }

      match /voiceKnocks/{knockId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && (isValidVoiceKnockCreate(request.resource.data.fromUid)
            || isValidVoiceEjectCreate());
        allow update: if isSignedIn() && (
          isVoiceKnockResponse(resource.data.toUid)
          || isVoiceKnockCancel(resource.data.fromUid)
          || isVoiceKnockReopen(resource.data.fromUid)
        );
        allow delete: if isSignedIn() && resource.data.fromUid == request.auth.uid;
      }

      match /openVoiceChannels/{channelId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidOpenVoiceChannelWrite(workspaceId, channelId);
        allow delete: if isSignedIn();
      }

      match /voicePoll/{pollId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && isValidVoicePollWrite()
          && request.resource.data.createdByUserId == request.auth.uid;
        allow update: if isSignedIn() && isValidVoicePollPatch();
        allow delete: if isSignedIn();
      }

      match /voiceRtc/{sessionId} {
        allow read: if isSignedIn();

        match /signals/{signalId} {
          allow read: if isRtcSignalParticipant();
          allow create: if isValidRtcSignalCreate();
          allow update, delete: if isRtcSignalParticipant();
        }
      }
    }
  }
}
