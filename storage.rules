rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /downloads/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /workspaces/{workspaceId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches('icon\\.(jpg|png|webp)')
        && firestore.get(/databases/(default)/documents/workspacesShared/$(workspaceId)).data.ownerId == request.auth.uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
