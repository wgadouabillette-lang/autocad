{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "backend/**/*.py": {
      "excludeFiles": "{.venv/**,**/__pycache__/**,**/tests/**,**/*.test.py,**/test_*.py}"
    }
  },
  "experimentalServices": {
    "landing": {
      "root": "landing",
      "routePrefix": "/",
      "framework": "vite"
    },
    "frontend": {
      "root": "frontend",
      "routePrefix": "/app",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "app/main.py",
      "framework": "fastapi",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/_/backend/api/$1"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/subprocessors",
      "destination": "/subprocessors.html"
    },
    {
      "source": "/app",
      "destination": "/app/"
    }
  ],
  "headers": [
    {
      "source": "/downloads/(.*)",
      "headers": [
        {
          "key": "Content-Disposition",
          "value": "attachment"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
