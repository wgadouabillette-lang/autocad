{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "landing": {
      "root": "landing",
      "routePrefix": "/",
      "framework": "vite"
    },
    "frontend": {
      "root": "frontend",
      "routePrefix": "/app",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "app/main.py",
      "framework": "fastapi",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/_/backend/api/$1"
    },
    {
      "source": "/auth",
      "destination": "/auth.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/app",
      "destination": "/app/"
    }
  ]
}
